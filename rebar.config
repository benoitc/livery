{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    {quic, {git, "https://github.com/benoitc/erlang_quic.git", {branch, "main"}}}
]}.

{project_plugins, [
    rebar3_ex_doc
]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {extras, [
        {"docs/getting_started.md", #{title => <<"Getting Started">>}},
        {"docs/handlers.md", #{title => <<"Handlers">>}},
        {"docs/request_response.md", #{title => <<"Request & Response">>}},
        {"docs/routing.md", #{title => <<"Routing">>}},
        {"docs/rest_api.md", #{title => <<"Building REST APIs">>}},
        {"docs/websocket.md", #{title => <<"WebSocket">>}},
        {"docs/middleware.md", #{title => <<"Middleware">>}},
        {"docs/streaming.md", #{title => <<"Streaming">>}},
        {"docs/configuration.md", #{title => <<"Configuration">>}},
        {"docs/telemetry.md", #{title => <<"Telemetry">>}},
        {"docs/module_reference.md", #{title => <<"Module Reference">>}}
    ]},
    {main, "getting_started"},
    {source_url, <<"https://github.com/benoitc/livery">>},
    {homepage_url, <<"https://github.com/benoitc/livery">>}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all, nowarn_missing_spec]},
        {deps, []}
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{dialyzer, [
    {warnings, [
        unknown
    ]},
    {plt_apps, all_deps}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% EUnit configuration - exclude compliance tests (run via CT)
{eunit_opts, [
    verbose,
    {skip_deps, true}
]}.

%% Explicitly list test modules for eunit (excludes compliance/* and SUITE tests)
{eunit_tests, [
    {module, livery_h1_parse_tests},
    {module, livery_hpack_tests},
    {module, livery_h2_frame_tests},
    {module, livery_qpack_tests},
    {module, livery_h3_frame_tests},
    {module, livery_router_tests},
    {module, livery_middleware_tests},
    {module, livery_ws_tests},
    {module, livery_telemetry_tests},
    {module, livery_info_tests},
    {module, livery_shutdown_tests}
]}.

%% CT configuration for compliance tests
{ct_opts, [
    {dir, "test/compliance"}
]}.
