{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, []}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all, nowarn_missing_spec]},
        {deps, []}
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{dialyzer, [
    {warnings, [
        unknown
    ]},
    {plt_apps, all_deps}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% EUnit configuration - exclude compliance tests (run via CT)
{eunit_opts, [
    verbose,
    {skip_deps, true}
]}.

%% Explicitly list test modules for eunit (excludes compliance/* and SUITE tests)
{eunit_tests, [
    {module, livery_h1_parse_tests},
    {module, livery_hpack_tests},
    {module, livery_h2_frame_tests},
    {module, livery_qpack_tests},
    {module, livery_h3_frame_tests},
    {module, livery_router_tests},
    {module, livery_middleware_tests},
    {module, livery_ws_tests},
    {module, livery_telemetry_tests},
    {module, livery_info_tests},
    {module, livery_shutdown_tests}
]}.

%% CT configuration for compliance tests
{ct_opts, [
    {dir, "test/compliance"}
]}.
